{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["server/**/*.ts", "scripts/**/*.ts", "vite.config.ts", "vitest.config.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
