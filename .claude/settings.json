{
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Waiting for your input\" with title \"Iran Watch · Claude Code\" sound name \"Ping\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/toddswepston/Projects/iran-watch/.claude/hooks/protect-env.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/toddswepston/Projects/iran-watch/.claude/hooks/prettier-format.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/toddswepston/Projects/iran-watch/.claude/hooks/eslint-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s http://localhost:7474 > /dev/null 2>&1 && echo 'Dev server is running on :8080.' || echo 'Dev server not running. Start with: npm run dev (local) or npm run docker:up (Docker).'"
          }
        ]
      }
    ]
  }
}
